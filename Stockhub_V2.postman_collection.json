                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v2/stocks/{{stockId}}/collaborators",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v2",
                "stocks",
                "{{stockId}}",
                "collaborators"
              ]
            },
            "description": "Ajoute un collaborateur au stock.\nRôles disponibles : EDITOR | VIEWER | VIEWER_CONTRIBUTOR\nHiérarchie : OWNER peut tout ajouter, EDITOR peut ajouter VIEWER/VIEWER_CONTRIBUTOR uniquement.\n\nL'id du collaborateur est auto-sauvegardé dans {{collaboratorId}}."
          },
          "response": []
        },
